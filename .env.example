# Database Configuration
# For Vercel deployment, configure one of the following:

# Option 1: PostgreSQL (Recommended)
DATABASE_URL=postgresql://user:password@host:5432/phone_store

# Option 2: MySQL
# DATABASE_URL=mysql://user:password@host:3306/phone_store

# Option 3: SQLite (for development/simple deployments)
# DATABASE_URL=sqlite:./data.db

# Admin Credentials (change these in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Server Configuration
PORT=3000
NODE_ENV=production
